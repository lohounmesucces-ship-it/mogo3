internal/sysdig/client.go

type team struct {
	ID   int    `json:"id"`
	Name string `json:"name"`
}

func (c *Client) FindTeamIDByName(ctx context.Context, ibmInstanceID, bearer, teamName string) (string, error) {
	want := strings.ToLower(strings.TrimSpace(teamName))
	if want == "" {
		return "", fmt.Errorf("empty teamName")
	}

	url := strings.TrimRight(c.Endpoint, "/") + "/api/teams"

	req, err := http.NewRequestWithContext(ctx, http.MethodGet, url, nil)
	if err != nil {
		return "", err
	}

	req.Header.Set("Authorization", normalizeBearer(bearer))
	req.Header.Set("IBMInstanceID", ibmInstanceID)
	req.Header.Set("Accept", "application/json")

	hc := &http.Client{Timeout: c.Timeout}
	resp, err := hc.Do(req)
	if err != nil {
		return "", err
	}
	defer resp.Body.Close()

	body, _ := io.ReadAll(resp.Body)
	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		return "", fmt.Errorf("sysdig list teams failed: %s - %s", resp.Status, string(body))
	}

	var arr []team
	if err := json.Unmarshal(body, &arr); err == nil {
		for _, t := range arr {
			if strings.ToLower(strings.TrimSpace(t.Name)) == want {
				return strconv.Itoa(t.ID), nil
			}
		}
	}

	var wrapped struct {
		Teams []team `json:"teams"`
	}
	if err := json.Unmarshal(body, &wrapped); err == nil {
		for _, t := range wrapped.Teams {
			if strings.ToLower(strings.TrimSpace(t.Name)) == want {
				return strconv.Itoa(t.ID), nil
			}
		}
	}

	return "", fmt.Errorf("team not found: %s", teamName)
}

func userAllowed(filePath, user string) bool {
	user = strings.TrimSpace(user)
	if user == "" {
		return false
	}

	b, err := os.ReadFile(filePath)
	if err != nil {
		return false
	}

	for _, line := range strings.Split(string(b), "\n") {
		if strings.TrimSpace(line) == user {
			return true
		}
	}
	return false
}

func withACL(next http.Handler) http.Handler {
	const postACL = "/apps/sysdig/data-save/www/api/acl/post_users.txt"
	const deleteACL = "/apps/sysdig/data-save/www/api/acl/delete_users.txt"

	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		user := strings.TrimSpace(os.Getenv("REMOTE_USER"))
		if user == "" {
			user = strings.TrimSpace(r.Header.Get("X-User"))
		}

		path := r.URL.Path

		if r.Method == http.MethodPost && strings.Contains(path, "/v1/alerts/standard") {
			if !userAllowed(postACL, user) {
				http.Error(w, "forbidden", http.StatusForbidden)
				return
			}
		}

		if r.Method == http.MethodDelete && strings.Contains(path, "/v1/alerts/delete") {
			if !userAllowed(deleteACL, user) {
				http.Error(w, "forbidden", http.StatusForbidden)
				return
			}
		}

		next.ServeHTTP(w, r)
	})
}




