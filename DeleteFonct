func (c *Client) DeleteAlert(ctx context.Context, ibmInstanceID, teamName, bearer string, id int) error {
	scopeValue, err := c.resolveTeamScope(ctx, ibmInstanceID, teamName, bearer)
	if err != nil {
		return err
	}

	url := fmt.Sprintf("%s/api/alerts/%d", strings.TrimRight(c.Endpoint, "/"), id)

	req, err := http.NewRequestWithContext(ctx, http.MethodDelete, url, nil)
	if err != nil {
		return err
	}

	req.Header.Set("Authorization", normalizeBearer(bearer))
	req.Header.Set("IBMInstanceID", ibmInstanceID)
	req.Header.Set("SysdigTeamID", scopeValue)

	hc := &http.Client{Timeout: c.Timeout}
	resp, err := hc.Do(req)
	if err != nil {
		return err
	}
	defer resp.Body.Close()

	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		body, _ := io.ReadAll(resp.Body)
		return fmt.Errorf("sysdig delete alert failed: %s - %s", resp.Status, string(body))
	}

	return nil
}


func (c *Client) resolveTeamScope(ctx context.Context, ibmInstanceID, teamName, bearer string) (string, error) {
	url := strings.TrimRight(c.Endpoint, "/") + "/api/teams"

	req, err := http.NewRequestWithContext(ctx, http.MethodGet, url, nil)
	if err != nil {
		return "", err
	}

	req.Header.Set("Authorization", normalizeBearer(bearer))
	req.Header.Set("IBMInstanceID", ibmInstanceID)

	hc := &http.Client{Timeout: c.Timeout}
	resp, err := hc.Do(req)
	if err != nil {
		return "", err
	}
	defer resp.Body.Close()

	body, _ := io.ReadAll(resp.Body)
	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
		return "", fmt.Errorf("failed to list teams: %s - %s", resp.Status, string(body))
	}

	var teams []struct {
		ID   int    `json:"id"`
		Name string `json:"name"`
	}

	if err := json.Unmarshal(body, &teams); err != nil {
		var wrapper struct {
			Teams []struct {
				ID   int    `json:"id"`
				Name string `json:"name"`
			} `json:"teams"`
		}
		if err2 := json.Unmarshal(body, &wrapper); err2 != nil {
			return "", err
		}
		for _, t := range wrapper.Teams {
			if strings.EqualFold(strings.TrimSpace(t.Name), strings.TrimSpace(teamName)) {
				return strconv.Itoa(t.ID), nil
			}
		}
		return "", fmt.Errorf("team not found: %s", teamName)
	}

	for _, t := range teams {
		if strings.EqualFold(strings.TrimSpace(t.Name), strings.TrimSpace(teamName)) {
			return strconv.Itoa(t.ID), nil
		}
	}

	return "", fmt.Errorf("team not found: %s", teamName)
}
